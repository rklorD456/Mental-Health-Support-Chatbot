# Lightning AI API (used for LLM inference — intent classification, RAG, translation)
LIGHTNING_API_KEY=your_lightning_api_key_here
LIGHTNING_BASE_URL=https://lightning.ai/api/v1

# Qdrant Vector Database
QDRANT_URL=https://your-qdrant-cloud-url.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key_here

# Optional: API key for authenticating incoming requests to this app
# If set, clients must send X-API-Key header with this value
APP_API_KEY=

# Optional: Rate limit (default: 30/minute)
RATE_LIMIT=30/minute
